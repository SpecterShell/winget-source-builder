<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  IgnorableNamespaces="uap uap3">

  <Identity Name="Winget.Source.Builder.Index"
    ProcessorArchitecture="neutral"
    Publisher="CN=Winget Source Builder"
    Version="1.0.0.0" />

  <Properties>
    <DisplayName>Winget Source Builder</DisplayName>
    <PublisherDisplayName>Winget Source Builder</PublisherDisplayName>
    <Logo>Assets\AppPackageStoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Applications>
    <Application Id="SourceData">
      <uap:VisualElements DisplayName="Winget Source Builder"
        Square150x150Logo="Assets\AppPackageStoreLogo.scale-150.png"
        Square44x44Logo="Assets\AppPackageStoreLogo.scale-100.png"
        Description="Static WinGet source data"
        BackgroundColor="#0078d7"
        AppListEntry="none" />
      <Extensions>
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension Name="com.microsoft.winget.source"
            Id="IndexDB"
            DisplayName="WinGet Source"
            Description="WinGet Source"
            PublicFolder="Public">
          </uap3:AppExtension>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Resources>
    <Resource Language="und" />
  </Resources>

</Package>
